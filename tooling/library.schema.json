{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "app-library library.json — pipeline single source of truth",
  "type": "object",
  "required": ["project", "updated", "ossBase", "modules"],
  "properties": {
    "project": { "type": ["object", "string"] },
    "reviewer": { "type": "string" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "ossBase": { "type": "string", "format": "uri" },
    "_schema": { "type": "string" },
    "promptSuffix": { "type": "string" },
    "rounds": { "type": "array" },
    "backups": { "type": "array" },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/definitions/module" }
    }
  },
  "definitions": {
    "module": {
      "type": "object",
      "required": ["id", "num", "slug", "tag", "cn", "name", "en", "desc", "built", "test", "prompt", "stages"],
      "properties": {
        "id": { "type": "string" },
        "num": { "type": "string" },
        "slug": { "type": "string", "pattern": "^[0-9]+-[a-z0-9-]+$" },
        "series": { "type": "string", "enum": ["v1", "v2"] },
        "kind": { "type": "string" },
        "tag": { "type": "string" },
        "cn": { "type": "string" },
        "name": { "type": "string" },
        "en": { "type": "string" },
        "desc": { "type": "string" },
        "built": { "type": "string", "enum": ["done", "building", "todo"] },
        "test": { "type": "string", "enum": ["none", "r1pass", "r2pass", "r1review", "r2review", "r3review"] },
        "status": { "type": "string" },
        "pageUid": { "type": ["string", "null"] },
        "proto": { "type": ["string", "null"] },
        "prompt": { "type": "string" },
        "branches": { "type": "object" },
        "stages": { "$ref": "#/definitions/stages" }
      }
    },
    "stages": {
      "type": "object",
      "required": ["proto", "spec", "built", "tested", "published"],
      "additionalProperties": false,
      "properties": {
        "proto":     { "type": "string", "enum": ["done", "todo"] },
        "spec":      { "type": "string", "enum": ["none", "machine", "human", "full"] },
        "built":     { "type": "string", "enum": ["done", "building", "todo"] },
        "tested":    { "type": "string", "enum": ["none", "r1pass", "r2pass", "r1review", "r2review", "r3review"] },
        "published": { "type": "string", "enum": ["no", "oss", "cms"] }
      }
    }
  }
}
