{
  "//": "Copy to bench.config.json and edit. One 'run' = one opencode TUI building into one NocoBase env.",

  "runCwd": "~",
  "opencodeConfig": "~/.config/opencode/opencode.json",
  "opencodeDb": "~/.local/share/opencode/opencode.db",
  "sessionPrefix": "bench",
  "tuiReadyTimeout": 90,

  "gateway": {
    "//": "OpenAI-compatible endpoint used ONLY by the LLM supervisor (monitor --judge llm).",
    "baseURL": "https://opencode.ai/zen/go/v1",
    "apiKeyEnv": "LLM_API_KEY"
  },

  "monitor": {
    "intervalSec": 60,
    "stallSec": 300,
    "judge": "heuristic+llm",
    "judgeModel": "qwen3.7-plus",
    "maxNudgesPerSession": 3,
    "nudgeCooldownSec": 200,
    "defaultNudge": "Continue. If blocked, state the exact blocker in one line, then proceed autonomously."
  },

  "runs": [
    {
      "id": "crm-r1",
      "env": "expagents",
      "model": "bailian-payg/qwen3.7-plus",
      "promptFile": "prompts/crm-native-1.prompt.txt",
      "reset": { "from": "~/bench-backups/pre-iterate-20260626/expagents.nbdata" }
    },
    {
      "id": "crm-r2",
      "env": "fable14232",
      "model": "bailian-payg/qwen3.7-plus",
      "promptFile": "prompts/crm-native-2.prompt.txt",
      "reset": { "from": "~/bench-backups/pre-iterate-20260626/fable14232.nbdata" }
    },
    {
      "id": "crm-r3",
      "env": "flash14231",
      "model": "bailian-payg/qwen3.7-plus",
      "promptFile": "prompts/crm-native-3.prompt.txt",
      "reset": { "from": "~/bench-backups/pre-iterate-20260626/flash14231.nbdata" }
    }
  ]
}
