# Copy to .env and fill in. Nothing here is committed (.env is gitignored).

# --- server ---
PORT=8080
# WEB_DIR=./web
# SCORES_FILE=./web/user-scores.json
# BENCH_LIVE_SCRIPT=./tooling/bench/bench-live.py

# --- bench-live (opencode SQLite db the live viewer reads) ---
# OPENCODE_DB=~/.local/share/opencode/opencode.db

# --- bench runner (tooling/bench/*) : only needed if you run the pipeline ---
# OpenAI-compatible gateway used to drive non-Claude models (e.g. OpenCode Zen Go)
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=
LLM_MODEL=qwen3.7-plus

# NocoBase instances the bench builds into (comma-separated env names known to `nb`)
NB_BENCH_ENVS=
NB_API_BASE_URL=
NB_ACCESS_TOKEN=

# --- Feishu/Lark status push (optional; scripts/push-feishu.py) ---
FEISHU_OPEN_ID=
LARK_CLI=lark-cli
