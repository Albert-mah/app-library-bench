{
  "name": "app-library-bench",
  "version": "0.1.0",
  "private": true,
  "description": "A gallery + review center + model×flow benchmarking pipeline for AI-reproduced business apps (NocoBase).",
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env server/index.mjs",
    "dev": "node --watch --env-file-if-exists=.env server/index.mjs",
    "validate": "python3 tooling/validate-library.py",
    "bench": "python3 tooling/bench/bench.py run",
    "bench:status": "python3 tooling/bench/bench.py status",
    "bench:monitor": "python3 tooling/bench/bench.py monitor",
    "bench:summary": "python3 tooling/bench/bench.py summary",
    "bench:stop": "python3 tooling/bench/bench.py stop"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "license": "MIT"
}
